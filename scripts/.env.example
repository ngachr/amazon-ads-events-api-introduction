```bash
# ============================================
# Amazon Ads Events API - Environment Variables
# ============================================

# Login with Amazon (LwA) App Credentials
CLIENT_ID=your_amazon_advertising_api_client_id
CLIENT_SECRET=your_client_secret
REDIRECT_URI=your_redirect_uri

# Tokens (generated by get_access_token.py)
REFRESH_TOKEN=your_refresh_token
ACCESS_TOKEN=your_bearer_access_token

# Advertiser Account (retrieved by get_advertiser_accounts.py)
# Use the "DSP Advertiser ID" from the output — this is the value sent as the
# 'Amazon-Ads-AccountId' header when creating events
ACCOUNT_ID=your_dsp_advertiser_id
